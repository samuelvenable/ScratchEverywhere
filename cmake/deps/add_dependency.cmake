set(_SE_DEPS_DIR "${CMAKE_CURRENT_LIST_DIR}" CACHE INTERNAL "internal stuff idk")

function(_check_dep_target DEP_NAME)
    if(TARGET deps::${DEP_NAME})
		return()
	endif()

	set(CANDIDATES ${DEP_NAME} ${DEP_NAME}::${DEP_NAME} ${DEP_NAME}::${DEP_NAME}-static PkgConfig::${DEP_NAME})
	
	foreach(CANDIDATE ${CANDIDATES})
		if(TARGET ${CANDIDATE})
			get_target_property(IS_ALIAS ${CANDIDATE} ALIASED_TARGET)
			if(IS_ALIAS)
				add_library(deps::${DEP_NAME} ALIAS ${IS_ALIAS})
			else()
				add_library(deps::${DEP_NAME} ALIAS ${CANDIDATE})
			endif()

			break()
		endif()
	endforeach()
endfunction()

function(se_add_dependency FIRST_ARG)
	if(${ARGC} EQUAL 1)
        set(TARGET_NAME "")
		set(DEP_NAME "${FIRST_ARG}")
    else()
		set(TARGET_NAME "${FIRST_ARG}")
        set(DEP_NAME "${ARGV1}")
    endif()

	if(NOT TARGET_NAME STREQUAL "")
		get_target_property(TARGET_TYPE ${TARGET_NAME} TYPE)
		if(TARGET_TYPE STREQUAL "INTERFACE_LIBRARY")
			set(LINK_SCOPE "INTERFACE")
		else()
			set(LINK_SCOPE "PRIVATE")
		endif()
	endif()

	if(TARGET deps::${DEP_NAME})
		if(NOT TARGET_NAME STREQUAL "")
			target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
		endif()
		return()
	endif()

	set(DEP_SCRIPT "${_SE_DEPS_DIR}/${DEP_NAME}.cmake")
	if(NOT EXISTS ${DEP_SCRIPT})
        message(FATAL_ERROR "Dependency definition not found at ${DEP_SCRIPT}")
    endif()
	include(${DEP_SCRIPT})
	_check_dep_target(${DEP_NAME})

	if(TARGET deps::${DEP_NAME})
		if(NOT TARGET_NAME STREQUAL "")
			target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
		endif()
		return()
	endif()

	if(((SE_DEPS STREQUAL "system" OR SE_DEPS STREQUAL "fallback") AND NOT SE_FORCE_SOURCE_${DEP_NAME}) OR SE_FORCE_SYSTEM_${DEP_NAME})
		cmake_language(CALL _dep_system_${DEP_NAME})
		_check_dep_target(${DEP_NAME})
	endif()

	if(NOT TARGET deps::${DEP_NAME})
		if(((SE_DEPS STREQUAL "source" OR SE_DEPS STREQUAL "fallback") AND NOT SE_FORCE_SYSTEM_${DEP_NAME}) OR SE_FORCE_SOURCE_${DEP_NAME})
			cmake_language(CALL _dep_source_${DEP_NAME})
			_check_dep_target(${DEP_NAME})
		endif()
	endif()

	if(NOT TARGET deps::${DEP_NAME})
		message(FATAL_ERROR "Failed to resolve dependency: ${DEP_NAME}")
		return()
	endif()

	if(NOT TARGET_NAME STREQUAL "")
		target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
	endif()
endfunction()
